// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TripStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum MessageRole {
  USER
  ASSISTANT
}

model User {
  id          String   @id @default(uuid())
  clerkId     String   @unique
  email       String   @unique
  fullName    String?
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trips         Trip[]
  conversations Conversation[] // 👈 Connect User to their chat threads
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  tripId    String?  @unique // 👈 Nullable while chatting, becomes Unique once Trip is built
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip     Trip?     @relation(fields: [tripId], references: [id], onDelete: SetNull) // 👈 3. Links to optional Trip
  messages Message[] // 👈 One-to-many link down to chat components
}

model Trip {
  id            String     @id @default(uuid())
  title         String
  destination   String
  origin        String?
  startDate     DateTime?
  endDate       DateTime?
  budget        Float?
  status        TripStatus @default(DRAFT)
  itineraryJson Json
  userId        String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  versions     TripVersion[]
  conversation Conversation? // 👈 Automatically handles the reverse relationship map link
}

model Message {
  id             String      @id @default(uuid())
  conversationId String // 👈 Messages are strictly bound to Conversations now, not Trips!
  role           MessageRole @default(USER)
  content        String
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model TripVersion {
  id String @id @default(uuid())

  versionNumber Int

  itineraryJson Json

  tripId String

  createdAt DateTime @default(now())

  // Very useful later
  changeSummary String?

  createdBy String? // "ai" | "user" | "system"

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, versionNumber])
}
